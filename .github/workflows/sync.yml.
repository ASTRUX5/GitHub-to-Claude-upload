name: Supabase GitHub Sync

on:
  repository_dispatch:
    types: [github_sync]

jobs:
  sync:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          token: ${{ secrets.GH_PAT }}

      - name: Process sync action
        env:
          GH_PAT: ${{ secrets.GH_PAT }}
          ACTION: ${{ github.event.client_payload.action }}
          REPO: ${{ github.event.client_payload.repo }}
          FILE_PATH: ${{ github.event.client_payload.file_path }}
          CONTENT: ${{ github.event.client_payload.content }}
          RECORD_ID: ${{ github.event.client_payload.id }}
          SUPABASE_URL: ${{ secrets.SUPABASE_URL }}
          SUPABASE_KEY: ${{ secrets.SUPABASE_KEY }}
        run: |
          git config user.email "claude-bot@github.com"
          git config user.name "Claude Bot"

          if [ "$ACTION" = "upsert" ]; then
            mkdir -p "$(dirname "$FILE_PATH")"
            echo "$CONTENT" > "$FILE_PATH"
            git add "$FILE_PATH"
            git commit -m "Claude: upsert $FILE_PATH"
            git push
          elif [ "$ACTION" = "delete" ]; then
            git rm -f "$FILE_PATH"
            git commit -m "Claude: delete $FILE_PATH"
            git push
          fi

          # Mark as done in Supabase
          curl -s -X PATCH "$SUPABASE_URL/rest/v1/github_sync?id=eq.$RECORD_ID" \
            -H "apikey: $SUPABASE_KEY" \
            -H "Authorization: Bearer $SUPABASE_KEY" \
            -H "Content-Type: application/json" \
            -d '{"status":"done"}'
